<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <!-- Date Navigation Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#9C27B0">

        <Button
            android:id="@+id/btnPrevDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvCurrentDay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Today"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCurrentDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01/01/2024"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnNextDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="20sp" />

    </LinearLayout>

    <!-- School Type Selection -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnAddSchool"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add School"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnAddAfter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add After School" />

        <Button
            android:id="@+id/btnInviteFriend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Invite Friend"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- School Events RecyclerView -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="School Events"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:background="#E1BEE7" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSchoolEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:background="#FFFFFF" />

    <!-- After School Events RecyclerView -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="After School Events"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:background="#C5CAE9" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAfterSchoolEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:background="#FFFFFF" />

</LinearLayout>
