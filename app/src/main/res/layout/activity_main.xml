<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Date Navigation Header -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/holo_purple">

        <Button
            android:id="@+id/btnPrevDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Previous Day"/>

        <TextView
            android:id="@+id/tvCurrentDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvCurrentDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnNextDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Day"/>
    </LinearLayout>

    <!-- School Type Selection -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/btnAddSchool"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add School"/>

        <!-- "Add After" and "Invite Friend" buttons similarly -->
    </LinearLayout>

    <!-- Add Lesson Button -->
    <Button
        android:id="@+id/btnAddLesson"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Lesson"
        android:layout_gravity="center"/>

    <!-- Recycler Views -->
    <RecyclerView
        android:id="@+id/rvSchoolEvents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <RecyclerView
        android:id="@+id/rvAfterSchoolEvents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
