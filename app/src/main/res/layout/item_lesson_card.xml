<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Colored vertical indicator per subject -->
        <View
            android:id="@+id/viewSubjectIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:background="@color/colorSubjectDefault" />

        <!-- Time + lesson number column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textLessonNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                tools:text="Lesson 1" />

            <TextView
                android:id="@+id/textTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary"
                tools:text="08:30 – 09:15" />
        </LinearLayout>

        <!-- Main lesson / event details + optional actions for after-school events -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/textSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                tools:text="Subject: Mathematics" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutEditSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:visibility="gone"
                android:hint="@string/subject">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editSubject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/textTeacher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Teacher: John Smith" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutEditTeacher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:visibility="gone"
                android:hint="@string/teacher">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTeacher"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/textClassroom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Classroom: 233" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutEditClassroom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:visibility="gone"
                android:hint="@string/classroom">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editClassroom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- After-school event actions: delete, share, reminder, mark as done -->
            <LinearLayout
                android:id="@+id/layoutAfterSchoolActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/checkAfterSchoolDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true" />

                <ImageButton
                    android:id="@+id/buttonAfterSchoolShare"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/task_share"
                    android:src="@android:drawable/ic_menu_share" />

                <ImageButton
                    android:id="@+id/buttonAfterSchoolReminder"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/task_reminder"
                    android:src="@drawable/ic_reminder" />

                <ImageButton
                    android:id="@+id/buttonAfterSchoolDelete"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:contentDescription="@string/task_delete"
                    android:src="@android:drawable/ic_menu_delete" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
